rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Analytics (public write for tracker, admin read) ───
    // Allow unauthenticated pageview tracking from public site
    match /analytics/pageviews/events/{eventId} {
      allow create: if true;  // Public site tracker writes here
      allow read: if request.auth != null;  // Only logged-in admins can read
      allow update, delete: if false;  // Events are immutable
    }
    
    // Daily aggregates
    match /analytics/daily/{dateId}/{docId} {
      allow create, update: if true;  // Tracker aggregates here
      allow read: if request.auth != null;
      allow delete: if false;
    }

    // ─── Practice Data (authenticated only) ───
    match /appointments/{docId} {
      allow read, write: if request.auth != null;
    }

    match /patients/{patientId} {
      allow read, write: if request.auth != null;
    }
    match /patients/{patientId}/history/{historyId} {
      allow read, write: if request.auth != null;
    }

    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Conversations (public create for chat widget) ───
    match /conversations/{docId} {
      allow create: if true;  // Public widget creates conversation sessions
      allow read, update: if request.auth != null;
      allow delete: if false;
    }
    match /conversations/{sessionId}/messages/{msgId} {
      allow create: if true;  // Public chat creates messages
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // ─── KPI Benchmarks ───
    match /kpi_benchmarks/{specialty} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Practice Config (wizard data, public read) ───
    match /practice-config/{docId} {
      allow read: if true;  // Widget needs to read practice config
      allow write: if request.auth != null;
    }

    // ─── Website Content (public read, admin write) ───
    match /website/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ═══ Audit Logs (HIPAA §164.312(b)) ═══
    // Only authenticated admins can write audit logs
    // Audit logs are append-only — no updates or deletes allowed
    match /audit_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if false;  // Immutable audit trail
    }
  }
}
