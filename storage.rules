rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ═══ Clinical Documents (HIPAA §164.312(a)(1)) ═══
    // Only authenticated users can read/write clinical files
    // Files are organized by patient ID for isolation
    
    match /patients/{patientId}/xrays/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024  // Max 25MB per file
                   && request.resource.contentType.matches('image/.*|application/pdf|application/dicom');
      allow delete: if request.auth != null;
    }
    
    match /patients/{patientId}/photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // Max 10MB per photo
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
    
    match /patients/{patientId}/documents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024  // Max 50MB for documents
                   && request.resource.contentType.matches('application/pdf|image/.*');
      allow delete: if request.auth != null;
    }
    
    // ═══ Practice Assets (non-PHI) ═══
    // Avatar images, logos, team photos, etc.
    match /practice/{allPaths=**} {
      allow read: if true;  // Public assets
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024;
    }
    
    // ═══ Staff Photos ═══
    match /staff/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
